pipeline {
    agent any

    environment {
        IMAGE_NAME     = "secure-task-api"
        IMAGE_TAG      = "v2"
        FULL_IMAGE     = "${IMAGE_NAME}:${IMAGE_TAG}"
        CONTAINER_NAME = "secure-task-api-v2"
        APP_PORT       = "5000"
        HOST_PORT      = "5000"
        APP_URL        = "http://localhost:${HOST_PORT}"
        GITLEAKS_CMD   = 'C:\\Users\\asngo\\AppData\\Local\\Microsoft\\WinGet\\Packages\\Gitleaks.Gitleaks_Microsoft.Winget.Source_8wekyb3d8bbwe\\gitleaks.exe'
        ZAP_CMD        = 'C:\\Program Files\\ZAP\\Zed Attack Proxy\\zap.bat'

        // ── Variables pour l'analyse IA Ollama (LLM local, 100% gratuit) ──
        // Pas de clé API nécessaire — Ollama tourne sur la même machine que Jenkins
        OLLAMA_MODEL   = "mistral"         // Modèle téléchargé avec : ollama pull mistral
        OLLAMA_URL     = "http://localhost:11434/api/generate"
        REPORT_DIR     = "${WORKSPACE}\\reports"
        EMAIL_CONFIG   = "${WORKSPACE}\\email_config.json"
        PYTHON         = "venv\\Scripts\\python"
    }

    options {
        timestamps()
    }

    stages {

        // ─────────────────────────────────────────────────────────────────
        // Stages existants — INCHANGÉS
        // ─────────────────────────────────────────────────────────────────

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Setup Python Environment') {
            steps {
                bat '''
                py -3 -m venv venv
                venv\\Scripts\\python -m pip install --upgrade pip
                venv\\Scripts\\python -m pip install -r requirements.txt
                venv\\Scripts\\python -m pip install flake8 pytest bandit pip-audit
                venv\\Scripts\\python -m pip install requests weasyprint
                '''
            }
            // Seul ajout : "requests weasyprint" à la fin du pip install
            // requis par analyze_pipeline.py pour l'analyse IA et la génération PDF
            // Si weasyprint pose problème : retirez-le et ajoutez --no-pdf dans le stage AI Analysis
        }

        stage('Lint - Flake8') {
            steps {
                bat '''
                venv\\Scripts\\python -m flake8 app.py test_app.py
                '''
            }
        }

        stage('Tests - Pytest') {
            steps {
                bat '''
                venv\\Scripts\\python -m pytest -v
                '''
            }
        }

        stage('Security - Bandit') {
            steps {
                bat '''
                venv\\Scripts\\python -m bandit -r app.py -s B104
                '''
            }
        }

        stage('Security - pip-audit') {
            steps {
                bat '''
                venv\\Scripts\\python -m pip_audit
                '''
            }
        }

        stage('Security - Gitleaks') {
            steps {
                bat '''
                %GITLEAKS_CMD% detect --source . --verbose
                '''
            }
        }

        stage('Build Docker Image') {
            steps {
                bat '''
                docker build -t %FULL_IMAGE% .
                '''
            }
        }

        stage('Security - Trivy') {
            steps {
                bat '''
                trivy image --severity HIGH,CRITICAL %FULL_IMAGE%
                '''
            }
        }

        stage('Deploy Local Container') {
            steps {
                bat '''
                docker rm -f %CONTAINER_NAME% >nul 2>&1
                docker run -d --name %CONTAINER_NAME% -p %HOST_PORT%:%APP_PORT% %FULL_IMAGE%
                '''
            }
        }

        stage('Wait for Application') {
            steps {
                bat '''
                powershell -Command "Start-Sleep -Seconds 8"
                '''
            }
        }

        stage('Check Application Availability') {
            steps {
                bat '''
                powershell -Command "Invoke-WebRequest -Uri %APP_URL% -UseBasicParsing | Select-Object StatusCode"
                '''
            }
        }

        stage('DAST - OWASP ZAP') {
            steps {
                bat '''
                cd /d "C:\\Program Files\\ZAP\\Zed Attack Proxy"
                zap.bat -cmd -quickurl http://localhost:5000 -quickout "C:\\ProgramData\\Jenkins\\.jenkins\\workspace\\secure-task-api-v2\\zap_report.html"
                '''
            }
        }

        // ─────────────────────────────────────────────────────────────────
        // NOUVEAU stage — Analyse IA des logs avec Ollama (local, gratuit)
        // Prérequis sur la machine Jenkins :
        //   1. Ollama installé   : https://ollama.com/download
        //   2. Modèle téléchargé : ollama pull mistral
        //   3. Service démarré   : ollama serve  (ou service Windows installé)
        // Fichiers requis dans votre repo GitHub :
        //   - analyze_pipeline.py  (fourni)
        //   - email_config.json    (fourni — à personnaliser avec vos infos SMTP)
        // ─────────────────────────────────────────────────────────────────
        stage('AI Analysis - Ollama') {
            steps {
                // Vérifie qu'Ollama tourne (le démarre si configuré comme service Windows)
                bat '''
                powershell -Command "
                  try {
                    $r = Invoke-WebRequest -Uri http://localhost:11434/api/tags -UseBasicParsing -TimeoutSec 3
                    Write-Host '✅ Ollama est démarré'
                  } catch {
                    Write-Host '⚠️  Ollama non détecté sur localhost:11434'
                    Write-Host 'Démarrez Ollama manuellement : ollama serve'
                  }
                "
                '''

                script {
                    // Capture tous les logs du build courant
                    def logLines = currentBuild.rawBuild.getLog(50000)
                    writeFile file: 'pipeline.log', text: logLines.join('\n')
                }

                bat '''
                if not exist reports mkdir reports

                %PYTHON% analyze_pipeline.py ^
                    --log pipeline.log ^
                    --output reports ^
                    --model %OLLAMA_MODEL% ^
                    --email-config %EMAIL_CONFIG%
                '''
                // En cas de problème avec weasyprint (PDF), ajoutez : --no-pdf
            }
        }
    }

    // ─────────────────────────────────────────────────────────────────────
    // post block — légèrement restructuré :
    //   1. archiveArtifacts inclut maintenant reports/**
    //   2. publishHTML ajouté pour afficher le rapport IA dans Jenkins
    //   3. cleanWs() déplacé APRÈS archivage (était avant = bug silencieux)
    // ─────────────────────────────────────────────────────────────────────
    post {
        success {
            echo 'Pipeline termine avec succes.'
            echo "Application deployee localement sur le port ${HOST_PORT}."
        }
        failure {
            echo 'Le pipeline a echoue. Verifie les logs Jenkins.'
        }
        always {
            archiveArtifacts(
                artifacts: 'zap_report.html, reports/**, **/*.css, **/*.js, **/*.png',
                fingerprint: true,
                allowEmptyArchive: true
            )
            // Publie le rapport HTML IA directement dans l'interface Jenkins
            // Requiert le plugin "HTML Publisher" (Manage Jenkins → Plugins → Available)
            publishHTML(target: [
                allowMissing         : true,
                alwaysLinkToLastBuild: true,
                keepAll              : true,
                reportDir            : 'reports',
                reportFiles          : 'report_*.html',
                reportName           : '📊 Rapport IA CI/CD (Ollama)'
            ])
            cleanWs()
        }
    }
}